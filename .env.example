# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_SECRET=your_webhook_secret_here
DATABASE_URL=postgres://user:password@localhost:5432/ilya_bot?sslmode=disable
DEEPSEA_API_KEY=your_deepseek_api_key_here
CANDIDATE_TELEGRAM_ID=123456789

# Optional (with defaults)
LLM_ENABLED=true
PORT=8080

# Embedding / similarity search (optional – requires pgvector in PostgreSQL)
# Set EMBEDDING_ENABLED=true and provide an API key to enable auto-answering.
EMBEDDING_ENABLED=false
# API key for the embeddings provider (defaults to DEEPSEA_API_KEY if unset)
EMBEDDING_API_KEY=your_openai_or_compatible_api_key_here
# Base URL of the OpenAI-compatible embeddings endpoint (default: https://api.openai.com)
EMBEDDING_BASE_URL=https://api.openai.com
# Embedding model name (default: text-embedding-ada-002)
EMBEDDING_MODEL=text-embedding-ada-002
# Cosine-similarity threshold [0,1] above which a stored answer is reused (default: 0.85)
SIMILARITY_THRESHOLD=0.85
